{
  "name": "Noise Pad",
  "version": 1,
  "polyphony": 4,
  "play_mode": "poly",
  "pan_spread": 1.0,
  "master_volume": 0.7,
  "portamento_time": 0.0,
  "pitch_bend_range": 2.0,
  "voice": {
    "oscillators": [
      { "type": "noise", "level": 0.8, "detune": 0.0, "octave": 0, "pulse_width": 0.5, "pan": 0.0, "pan_spread": 1.0 },
      { "type": "off",   "level": 0.5, "detune": 0.0, "octave": 0, "pulse_width": 0.5, "pan": 0.0, "pan_spread": 1.0 }
    ],
    "sub_level": 0.0,
    "ring_mod": 0.0,
    "filter": { "type": "bp", "cutoff": 800.0, "resonance": 0.55, "env_amount": 0.0, "vel_amount": 0.0 },
    "filter_envelope": { "attack": 500.0, "decay": 500.0, "sustain": 1.0, "release": 1000.0 },
    "amp_envelope":    { "attack": 2000.0, "decay": 500.0, "sustain": 0.9, "release": 4000.0 }
  },
  "effects": [
    { "type": "reverb", "mix": 0.55, "t60": 5.0 },
    { "type": "off", "mix": 0.0 },
    { "type": "off", "mix": 0.0 },
    { "type": "off", "mix": 0.0 }
  ],
  "lfos": [
    { "shape": "sine", "rate": 0.18, "depth": 0.6, "targets": [{ "param": "filter.cutoff", "depth": 0.5 }] },
    { "shape": "tri",  "rate": 0.05, "depth": 0.3, "targets": [{ "param": "amp",           "depth": 0.2 }] },
    { "shape": "sine", "rate": 1.0,  "depth": 0.0, "targets": [] },
    { "shape": "sine", "rate": 1.0,  "depth": 0.0, "targets": [] }
  ],
  "macros": [
    { "value": 0.0, "cc": -1, "targets": [] },
    { "value": 0.0, "cc": -1, "targets": [] },
    { "value": 0.0, "cc": -1, "targets": [] },
    { "value": 0.0, "cc": -1, "targets": [] }
  ]
}
