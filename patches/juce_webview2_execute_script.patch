diff --git a/modules/juce_gui_extra/native/juce_WebBrowserComponent_windows.cpp b/modules/juce_gui_extra/native/juce_WebBrowserComponent_windows.cpp
index 209c05025a..f4b1c29d39 100644
--- a/modules/juce_gui_extra/native/juce_WebBrowserComponent_windows.cpp
+++ b/modules/juce_gui_extra/native/juce_WebBrowserComponent_windows.cpp
@@ -459,6 +459,15 @@ public:
 
     void goToURL (const String& url, const StringArray* headers, const MemoryBlock* postData) override
     {
+        // javascript: URIs must be executed via ExecuteScript, not Navigate.
+        // Calling Navigate("javascript:...") on WebView2 treats it as a real
+        // navigation, which fires NavigationCompleted and can blank the page.
+        if (webView != nullptr && url.startsWithIgnoreCase ("javascript:"))
+        {
+            webView->ExecuteScript (url.substring (11).toWideCharPointer(), nullptr);
+            return;
+        }
+
         urlRequest = { url,
                        headers != nullptr ? *headers : StringArray(),
                        postData != nullptr && postData->getSize() > 0 ? *postData : MemoryBlock() };
