+        // Prevent the white flash before page content renders.
+        // Setting drawsBackground:NO makes the view transparent so the dark
+        // CALayer behind it is visible during load instead of the default white.
+        [webView.get() setValue: @(NO) forKey: @"drawsBackground"];
+        [webView.get() setWantsLayer: YES];
+        webView.get().layer.backgroundColor = CGColorCreateSRGB (18.0 / 255.0, 18.0 / 255.0, 18.0 / 255.0, 1.0);
